{
  "dataset_name": "roi_train2",
  "train_home": "${PROJECT_ROOT}/training",
  "experiment_name": "TEST",
  "base_label_config": "label_config.jsonc",
  "base_monai_config": "monai_config.jsonc",
  "param_grid": {
    "preprocessing": {},
    "training": {
      "num_images_per_batch": [1, 2, 4],
      "loss": [
        {
          "_target_": "DiceCELoss",
          "include_background": true,
          "squared_pred": true,
          "smooth_nr": 0,
          "smooth_dr": 1.0e-05,
          "softmax": "$not @sigmoid",
          "sigmoid": "$@sigmoid",
          "to_onehot_y": "$not @sigmoid"
        },
        {
          "_target_": "DiceCELoss",
          "include_background": false,
          "squared_pred": true,
          "smooth_nr": 0,
          "smooth_dr": 1.0e-05,
          "softmax": "$not @sigmoid",
          "sigmoid": "$@sigmoid",
          "to_onehot_y": "$not @sigmoid"
        },
        {
          "_target_": "DiceCELoss",
          "include_background": true,
          "weight": "$torch.tensor([1.0, 1.0, 5.0]).cuda()",
          "squared_pred": true,
          "smooth_nr": 0,
          "smooth_dr": 1.0e-05,
          "softmax": "$not @sigmoid",
          "sigmoid": "$@sigmoid",
          "to_onehot_y": "$not @sigmoid"
        },
        {
          "_target_": "DiceCELoss",
          "include_background": false,
          "weight": "$torch.tensor([1.0, 1.0, 5.0]).cuda()",
          "squared_pred": true,
          "smooth_nr": 0,
          "smooth_dr": 1.0e-05,
          "softmax": "$not @sigmoid",
          "sigmoid": "$@sigmoid",
          "to_onehot_y": "$not @sigmoid"
        }
      ]
    },
    "training_ids": {
      "num_images_per_batch": [1, 2, 4],
      "loss": ["bg-nowt", "nobg-nowt", "bg-wt115", "nobg-wt115"]
    }
  },
  "param_grid_ids": {
    
  }
}
